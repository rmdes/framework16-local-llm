#!/usr/bin/env bash
# llama-vulkan-mode — temporarily swap the GPU to the Vulkan backend.
#
# The 8 GB dGPU fits only one 7B at a time, so the always-on ROCm service and a
# Vulkan server can't coexist. This stops the ROCm service, runs Vulkan in the
# foreground on :8081, and ALWAYS restarts the ROCm service when you exit (Ctrl-C).
#
#   llama-vulkan-mode               # Vulkan 7B on :8081
#   llama-vulkan-mode -m 3b -p 8082 # extra args pass through to llama-go
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVICE="${SERVICE:-llama}"

_restored=0
restore(){ [ "$_restored" = 1 ] && return; _restored=1
  echo; echo "==> restoring ROCm service ($SERVICE)…"
  systemctl --user start "$SERVICE" 2>/dev/null || true
}
trap restore INT TERM EXIT

echo "==> stopping ROCm service ($SERVICE) to free VRAM…"
systemctl --user stop "$SERVICE" 2>/dev/null || true

echo "==> starting Vulkan server on :8081 @ 32k ctx (Ctrl-C to stop and return to ROCm)…"
# 32k context matches the opencode `limit.context`; agentic clients inject huge
# system prompts + tool schemas, so the 8k default compaction-loops. -c is first
# so a user-supplied -c in "$@" still wins.
# NOT exec'd, so the trap survives to restore the service on exit.
"$HERE/llama-go" -b vulkan -p 8081 -c 32768 "$@"
